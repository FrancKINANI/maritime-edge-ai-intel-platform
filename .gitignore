# =============================================================================
# Maritime Edge AI Platform — .gitignore
# =============================================================================

# --- ONNX models (manual transfer) ---
/research/data/scenes/*
/research/data/tiles/*
/research/data/annotations/*
/shared/models/*
/research/results/*
!/shared/models/.gitkeep

# --- Python ---
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.egg-info/
.eggs/
dist/
build/
*.so

# --- Environment ---
.env
.env.local
.env.*.local

# --- IDE / OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Testing ---
.coverage
.pytest_cache/
htmlcov/
coverage_html/
.tox/
.hypothesis/

# --- Ruff ---
.ruff_cache/

# --- Temp ---
tmp/
temp/
*.tmp
*.bak
*.log
logs/

# --- Docker ---
.docker/

# --- Generated large data ---
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.npy
*.npz
*.SAFE
*.nc
*.geotiff
*.csv
*.xml
