# =============================================================================
# Maritime Edge AI Platform — .gitignore
# =============================================================================


# --- Phase 0 data (generated, large) ---
/phase_post0/dataset_finetune/
/phase_post0/models/
/phase0/data/
/phase0/docs/
/docs/
/data/

# --- Images (generated tiles, never committed) ---
*.png
*.jpg
*.jpeg
*.tif
*.tiff

# --- Large SAR / geospatial files ---
*.SAFE
*.nc
*.geotiff
*.npy

# --- Archives ---
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# --- Generated CSV/JSON/XML exports ---
*.csv
*.xml
!templates/*.csv

# --- ONNX models (manual transfer) ---
/shared/models/*
!/shared/models/.gitkeep

# --- Python ---
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.egg-info/
.eggs/
dist/
build/
*.so

# --- Environment ---
.env
.env.local
.env.*.local

# --- IDE / OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Testing ---
.coverage
.pytest_cache/
htmlcov/
.tox/
.hypothesis/

# --- Temp ---
tmp/
temp/
*.tmp
*.bak
*.log
logs/
