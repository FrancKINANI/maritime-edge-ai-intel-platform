# Example environment configuration for the maritime intelligence platform
# Copy this file to .env and fill in the required values.

# Copernicus Data Space Ecosystem credentials
CDSE_USERNAME=example@gmail.com
CDSE_PASSWORD=example_password

# Optional region overrides
ALGERIA_MED_BBOX=
ALGERIA_MED_NAME=Algeria Mediterranean
MAURITANIA_ATL_BBOX=
MAURITANIA_ATL_NAME=Mauritania Atlantic
SPAIN_MED_BBOX=
SPAIN_MED_NAME=Spain Mediterranean
PORTUGAL_ATL_BBOX=
PORTUGAL_ATL_NAME=Portugal Atlantic
