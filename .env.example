[TEMPLATE]
# Example environment configuration for the maritime intelligence platform
# Copy this file to .env and fill in the required values.

# Copernicus Data Space Ecosystem credentials (required for CDSE download)
CDSE_USERNAME=changeme@example.com
CDSE_PASSWORD=CHANGE_THIS_PASSWORD

# Global Fishing Watch API token (required for GFW annotations)
# Generate a token on https://globalfishingwatch.org/our-apis/
GFW_API_TOKEN=CHANGE_THIS_TOKEN

# Sentinel Hub credentials (optional, fallback if CDSE unavailable)
SENTINEL_HUB_CLIENT_ID=CHANGE_THIS_CLIENT_ID
SENTINEL_HUB_CLIENT_SECRET=CHANGE_THIS_CLIENT_SECRET

# Services (Docker)
REDIS_URL=redis://redis:6379
DATABASE_URL=sqlite:///./maritime_intel.db

# Default geographic region (Morocco, format: lon_min,lat_min,lon_max,lat_max)
REGION_BBOX=-17,27,-1,36
