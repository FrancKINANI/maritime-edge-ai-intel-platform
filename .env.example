[TEMPLATE]
# Example environment configuration for the maritime intelligence platform
# Copy this file to .env and fill in the required values.

# Copernicus Data Space Ecosystem credentials (obligatoire pour CDSE download)
CDSE_USERNAME=votre_email@gmail.com
CDSE_PASSWORD=votre_mot_de_passe

# Global Fishing Watch API token (obligatoire pour GFW annotations)
# Generer un token sur https://globalfishingwatch.org/our-apis/
GFW_API_TOKEN=votre_token_gfw

# Sentinel Hub credentials (optionnel, fallback si CDSE indisponible)
SENTINEL_HUB_CLIENT_ID=votre_client_id
SENTINEL_HUB_CLIENT_SECRET=votre_client_secret

# Services (demo locale)
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite:///./maritime_intel.db

# Region geographique par defaut (Maroc, format: lon_min,lat_min,lon_max,lat_max)
REGION_BBOX=-17,27,-1,36

# Parametres optionnels (regions secondaires)
# ALGERIA_MED_BBOX=
# ALGERIA_MED_NAME=Algeria Mediterranean
# MAURITANIA_ATL_BBOX=
# MAURITANIA_ATL_NAME=Mauritania Atlantic
# SPAIN_MED_BBOX=
# SPAIN_MED_NAME=Spain Mediterranean
# PORTUGAL_ATL_BBOX=
# PORTUGAL_ATL_NAME=Portugal Atlantic
